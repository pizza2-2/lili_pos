                const detailData = buildInitialDataFromDetail(detail, parentText);
                const kasaCategoryIdText = stringValue(detailData['kasa_category_id']);
                const currentKasaCategoryText = stringValue(detailData['kasa_category_text']);
                if (kasaCategoryIdText != '') {
