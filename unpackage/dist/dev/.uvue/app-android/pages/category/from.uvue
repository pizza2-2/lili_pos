        }
        function booleanValue(value: any | null, fallback: boolean = false): boolean {
            if (value == null) {
                return fallback;
            }
            const text = ('' + value).toLowerCase();
            return text == 'true' || text == '1' || text == 'yes';
        }
        function intValue(value: any | null, fallback: number = 0): number {
            if (value == null) {
                return fallback;
            }
            const text = '' + value;
            if (text == '') {
                return fallback;
            }
            const parsed = parseInt(text);
            if (isNaN(parsed)) {
                return fallback;
            }
            return parsed;
        }
        function parseErrorMessage(error: any, fallback: string): string {
            let message = fallback;
            if (error != null) {
                const directMessage = (error as Error).message;
                if (directMessage != null && directMessage != '') {
                    message = directMessage;
                }
                const errorText = JSON.stringify(error);
                if (errorText != null && errorText != '') {
                    const parsedError = UTSAndroid.consoleDebugError(JSON.parseObject<UTSJSONObject>(errorText), " at pages/category/from.uvue:130");
                    if (parsedError != null) {
                        const rawMessage = parsedError['message'];
                        if (rawMessage != null) {
