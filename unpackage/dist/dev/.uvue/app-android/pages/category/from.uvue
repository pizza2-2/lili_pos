        async function persistForm(payload: UTSJSONObject): Promise<void> {
            if (submitting.value) {
                return;
            }
            const formDataValue = payload['formData'];
            const data = formDataValue == null ? ({} as UTSJSONObject) : (formDataValue as UTSJSONObject);
            const name = stringValue(data['name']).trim();
            if (name == '') {
                uni.showToast({
                    title: '分类名称不能为空',
                    icon: 'none',
                });
                return;
            }
            submitting.value = true;
            const isEditing = formMode.value == 'edit' && categoryId.value != '';
            savingText.value = isEditing ? '保存分类中...' : '创建分类中...';
            savingVisible.value = true;
            uni.showLoading({
