                key: 'kasa_category',
                search: keyword == '' ? null : keyword,
                q: null,
                keyword: null,
                limit: 50,
            } as KasaCategoryOptionsQuery);
            const result: UTSJSONObject[] = [];
            for (let index = 0; index < response.items.length; index += 1) {
                const item = response.items[index];
                const value = stringValue(item['value'], stringValue(item['id']));
                const text = stringValue(item['text'], stringValue(item['label']));
                if (id != '' && value != id) {
                    continue;
                }
                result.push({
                    value: value,
                    text: text,
                } as UTSJSONObject);
            }
            return {
                data: result,
                total: result.length,
            } as UTSJSONObject;
        }
        async function resolveKasaCategoryTextByValue(kasaCategoryIdText: string, fallback: string = ''): Promise<string> {
            if (kasaCategoryIdText == '') {
                return '';
            }
            try {
                const response = await getKasaCategoryOptions({
                    key: 'kasa_category',
                    search: null,
                    q: null,
                    keyword: null,
                    limit: 200,
                } as KasaCategoryOptionsQuery);
                for (let index = 0; index < response.items.length; index += 1) {
                    const item = response.items[index];
                    const value = stringValue(item['value'], stringValue(item['id']));
                    if (value != kasaCategoryIdText) {
                        continue;
                    }
                    const text = stringValue(item['text'], stringValue(item['label']));
                    if (text != '') {
                        return text;
                    }
                }
            }
            catch (error: any) {
            }
            return fallback;
        }
        async function fetchParentOptions(params: UTSJSONObject): Promise<UTSJSONObject> {
            const keyword = stringValue(params['keyword']);
            const id = stringValue(params['id']);
            const response = await getCategoryList({
                search: keyword == '' ? null : keyword,
                page: 1,
                page_size: 50,
                id: id == '' ? null : id,
                is_active: null,
                level: null,
                parent: null,
                parent_id: null,
                code: null,
                tax_rate: null,
                kasa_category: null,
                kasa_category_id: null,
                status: null,
                ordering: 'name',
                simple: true,
            } as CategoryListQuery);
            const result: UTSJSONObject[] = [];
            if (id == '') {
                result.push({
                    value: '',
                    text: '根分类（无父分类）',
                } as UTSJSONObject);
            }
            for (let index = 0; index < response.results.length; index += 1) {
                const item = response.results[index];
                if (categoryId.value != '' && item.id.toString(10) == categoryId.value) {
                    continue;
                }
                result.push({
                    value: item.id.toString(10),
                    text: item.full_name == '' ? item.name : item.full_name,
                } as UTSJSONObject);
            }
            return {
                data: result,
                total: result.length,
            } as UTSJSONObject;
        }
        async function resolveParentText(parentIdText: string): Promise<string> {
            if (parentIdText == '') {
                return '根分类（无父分类）';
            }
            try {
                const parent = await getCategoryDetail(parentIdText);
                if (parent.full_name != '') {
                    return parent.full_name;
                }
                return parent.name;
            }
            catch (error: any) {
                return parentIdText;
            }
        }
        function parseObject(value: any | null): UTSJSONObject | null {
            if (value == null) {
