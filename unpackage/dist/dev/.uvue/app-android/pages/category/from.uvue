            const code = stringValue(formDataObject['code']);
            const description = stringValue(formDataObject['description']);
            const taxRate = stringValue(formDataObject['tax_rate'], '0.23');
            const sortOrder = intValue(formDataObject['sort_order'], 0);
            const isActive = booleanValue(formDataObject['is_active'], true);
