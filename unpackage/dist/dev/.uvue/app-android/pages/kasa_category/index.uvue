                    title: parseErrorMessage(error),
                    icon: 'none',
                });
            }
        }
        async function toggleSingleStatus(id: string, currentActive: boolean): Promise<void> {
            try {
                await patchKasaCategory(id, {
                    is_active: !currentActive,
                } as UTSJSONObject);
                uni.showToast({
