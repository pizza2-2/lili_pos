        function handleSelectionExit(payload: UTSJSONObject) {
            clearSelectionState();
        }
        function batchActionTitle(actionKey: string): string {
            if (actionKey == 'activate')
                return '批量启用';
            if (actionKey == 'deactivate')
                return '批量停用';
            if (actionKey == 'delete')
                return '批量删除';
            return '批量操作';
        }
        function batchActionConfirmText(actionKey: string, count: number): string {
            if (actionKey == 'activate')
                return '确定批量启用选中的 ' + count + ' 个收银分类吗？';
            if (actionKey == 'deactivate')
                return '确定批量停用选中的 ' + count + ' 个收银分类吗？';
            if (actionKey == 'delete')
                return '确定批量删除选中的 ' + count + ' 个收银分类吗？';
            return '确定执行批量操作吗？';
        }
        async function executeBatchAction(actionKey: string): Promise<void> {
            const items = selectedItems();
            if (items.length == 0) {
                uni.showToast({
                    title: '请先选择收银分类',
                    icon: 'none',
                });
                return;
            }
            try {
                for (let index = 0; index < items.length; index += 1) {
                    const item = items[index];
                    if (actionKey == 'delete') {
                        await deleteKasaCategory(item.id);
                        continue;
                    }
                    if (actionKey == 'activate') {
                        await patchKasaCategory(item.id, {
                            is_active: true,
                        } as UTSJSONObject);
                        continue;
                    }
                    if (actionKey == 'deactivate') {
                        await patchKasaCategory(item.id, {
                            is_active: false,
                        } as UTSJSONObject);
                        continue;
                    }
                }
                uni.showToast({
                    title: takeLatestResponseMessage(batchActionTitle(actionKey) + '成功'),
                    icon: 'success',
