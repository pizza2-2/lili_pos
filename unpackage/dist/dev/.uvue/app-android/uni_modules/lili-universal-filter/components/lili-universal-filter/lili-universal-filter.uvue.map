<template>
	<view class="uf-root" :style="rootStyle">
		<view class="uf-bar">
			<view v-if="showBack || showHome" class="uf-segment-group uf-segment-group-left">
				<view v-if="showBack" :class="showBack && showHome ? 'uf-segment uf-segment-split' : 'uf-segment'" @click="handleBack">
					<image class="uf-icon-image" src="/static/icon/左箭头.png" mode="aspectFit"></image>
				</view>
				<view v-if="showHome" class="uf-segment" @click="handleHome">
					<image class="uf-icon-image" src="/static/icon/主页.png" mode="aspectFit"></image>
				</view>
			</view>

			<view v-if="showSearch" class="uf-search-wrap">
				<view class="uf-search-box">
					<view v-if="showScan" class="uf-scan-btn" @click="handleScan">
						<text class="uf-scan-icon">▣</text>
					</view>
					<input
						class="uf-search-input"
						v-model="inputValue"
						:placeholder="searchPlaceholder"
						@input="onSearchInput"
						@confirm="onSearchConfirm"
						confirm-type="search"
					/>
					<view v-if="inputValue != ''" class="uf-clear-btn" @click="clearSearch">
						<text class="uf-clear-icon">×</text>
					</view>
				</view>
			</view>

			<view v-else class="uf-title-wrap">
				<text class="uf-title">{{ title }}</text>
			</view>

			<view v-if="showFilter || showMenu" class="uf-segment-group uf-segment-group-right">
				<view v-if="showFilter" :class="showFilter && showMenu ? 'uf-segment uf-segment-split uf-segment-light' : 'uf-segment uf-segment-light'" @click="handleFilter">
					<image class="uf-icon-image" src="/static/icon/_筛选.png" mode="aspectFit"></image>
					<view v-if="filterActive" class="uf-dot"></view>
				</view>
				<view v-if="showMenu" class="uf-segment uf-segment-dark" @click="handleMenu">
					<text class="uf-segment-icon-light">≡</text>
				</view>
			</view>
		</view>

		<page-container
			:show="filterPanelVisible"
			position="bottom"
			:round="true"
			:overlay="true"
			:duration="260"
			overlay-style="background-color: rgba(15, 23, 42, 0.38);"
			custom-style="background-color: #FFFFFF;"
			@clickoverlay="closeFilterPanel"
		>
			<view class="uf-filter-panel">
				<view class="uf-filter-handle"></view>
				<view class="uf-filter-header">
					<text class="uf-filter-title">筛选</text>
					<view class="uf-filter-close" @click="closeFilterPanel">
						<text class="uf-filter-close-text">关闭</text>
					</view>
				</view>
				<view class="uf-filter-body">
					<slot name="filter-panel">
						<view class="uf-filter-empty">
							<text class="uf-filter-empty-text">筛选面板内容待接入</text>
						</view>
					</slot>
				</view>
			</view>
		</page-container>
	</view>
</template>

<script setup lang="uts">
type Props = {
	title?: string
	searchPlaceholder?: string
	searchValue?: string
	filterVisible?: boolean
	showBack?: boolean
	showSearch?: boolean
	showFilter?: boolean
	showHome?: boolean
	showMenu?: boolean
	showScan?: boolean
	filterActive?: boolean
	filterText?: string
	fixed?: boolean
	backgroundColor?: string
	homePath?: string
}

const props = withDefaults(defineProps<Props>(), {
	title: '',
	searchPlaceholder: '请输入搜索内容',
	searchValue: '',
	filterVisible: false,
	showBack: false,
	showSearch: true,
	showFilter: false,
	showHome: false,
	showMenu: false,
	showScan: false,
	filterActive: false,
	filterText: '筛选',
	fixed: true,
	backgroundColor: '#FFFFFF',
	homePath: '/pages/tabbar/products',
})

const emit = defineEmits<{
	(e: 'back'): void
	(e: 'home'): void
	(e: 'menu'): void
	(e: 'filter'): void
	(e: 'filter-open'): void
	(e: 'filter-close'): void
	(e: 'update:filterVisible', value: boolean): void
	(e: 'scan'): void
	(e: 'searchInput', value: string): void
	(e: 'searchConfirm', value: string): void
	(e: 'searchClear'): void
}>()

const statusBarHeight = ref<number>(0)
const inputValue = ref<string>(props.searchValue)
const rootStyle = ref<string>('')
const filterPanelVisible = ref<boolean>(false)

function syncRootStyle() {
	const positionStyle = props.fixed ? 'position:sticky;top:0;' : ''
	rootStyle.value = `padding-top:${statusBarHeight.value}px;background-color:${props.backgroundColor};${positionStyle}`
}

function updateStatusBarHeight() {
	const info = uni.getWindowInfo()
	statusBarHeight.value = info.statusBarHeight
	syncRootStyle()
}

function onSearchInput() {
	emit('searchInput', inputValue.value)
}

function onSearchConfirm() {
	emit('searchConfirm', inputValue.value)
}

function clearSearch() {
	inputValue.value = ''
	emit('searchClear')
}

function handleBack() {
	emit('back')
	uni.navigateBack({
		delta: 1,
		fail: () => {
			uni.reLaunch({
				url: props.homePath,
			})
		},
	})
}

function handleHome() {
	emit('home')
	uni.reLaunch({
		url: props.homePath,
	})
}

function handleFilter() {
	filterPanelVisible.value = true
	emit('update:filterVisible', true)
	emit('filter-open')
}

function closeFilterPanel() {
	if (!filterPanelVisible.value) {
		return
	}
	filterPanelVisible.value = false
	emit('update:filterVisible', false)
	emit('filter-close')
}

function handleMenu() {
	emit('menu')
}

function handleScan() {
	emit('scan')
}

watch(
	() : string => props.searchValue,
	(newVal: string) => {
		if (newVal != inputValue.value) {
			inputValue.value = newVal
		}
	}
)

watch(
	() : boolean => props.filterVisible,
	(newVal: boolean) => {
		if (newVal != filterPanelVisible.value) {
			filterPanelVisible.value = newVal
		}
	}
)

watch(
	() : string => props.backgroundColor,
	() => {
		syncRootStyle()
	}
)

watch(
	() : boolean => props.fixed,
	() => {
		syncRootStyle()
	}
)

onMounted(() => {
	updateStatusBarHeight()
})
</script>

