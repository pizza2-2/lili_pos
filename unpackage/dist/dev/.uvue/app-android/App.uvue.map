<script lang="uts">
	import { isAgreePrivacyState } from '@/store/global'
	import { getAuthStateByStorageSync } from '@/store/auth'
	import { routerPermission,removeRouterPermission } from '@/pkg/router/permission'	//и·Ҝз”ұжӢҰжҲӘ
	

	import { registerOSPermission,unregisterOSPermission } from '@/pkg/util/osPermission'	//зі»з»ҹжқғйҷҗз”іиҜ·зӣёе…і

	

	let firstBackTime = 0


	export default {
		onLaunch: function () {
			console.log('App Launch')
			

			registerOSPermission()  	//е…ЁеұҖжіЁеҶҢзӣ‘еҗ¬зі»з»ҹжқғйҷҗз”іиҜ·

			getAuthStateByStorageSync() //еҗҢжӯҘд»Һжң¬ең°еӯҳеӮЁдёӯиҺ·еҸ–authStateзҡ„еҖј
			routerPermission()			//ж·»еҠ и·Ҝз”ұжӢҰжҲӘжқғйҷҗ
			

			// зӣ‘еҗ¬еҗҢж„Ҹйҡҗз§Ғж”ҝзӯ–зҠ¶жҖҒеҸҳеҢ–
			uni.onPrivacyAuthorizationChange((res)=>{
			    //жӣҙж–°еҗҢж„Ҹйҡҗз§Ғж”ҝзӯ–зҠ¶жҖҒ
				isAgreePrivacyState.value = !res.needAuthorization
			})
			// иҺ·еҸ–жҳҜеҗҰеҗҢж„Ҹйҡҗз§Ғж”ҝзӯ–
			uni.getPrivacySetting({
				success(res){
					// жіЁж„ҸiOSйҰ–ж¬ЎеҗҜеҠЁе°ҶдёҚдјҡеј№йҡҗз§Ғж”ҝзӯ–зӘ—еҸЈпјҲиӢ№жһңдёҠжһ¶еҜ№йҰ–ж¬Ўиҝӣе…Ҙappеј№зӘ—жІЎжңүиҰҒжұӮпјү
					if(res.needAuthorization){
						isAgreePrivacyState.value = false	// з”ЁжҲ·жңӘеҗҢж„Ҹйҡҗз§Ғж”ҝзӯ–
						// з”ЁжҲ·жңӘеҗҢж„Ҹйҡҗз§Ғж”ҝзӯ–еҲҷеј№еҮәвҖңдёӘдәәдҝЎжҒҜдҝқжҠӨжҢҮеј•вҖқжҸҗзӨәжЎҶ
						uni.openDialogPage({
							url: '/pages/privacy/privacy',  // дҝ®ж”№дёәеә”з”Ёдёӯе®ҡд№үзҡ„йЎөйқўең°еқҖ
						})
					}else{
						isAgreePrivacyState.value = true	// з”ЁжҲ·е·ІеҗҢж„Ҹйҡҗз§Ғж”ҝзӯ–
					}
				}
			})

		},
		onShow: function (options: OnShowOptions) {
			console.log('App Show')
			
			console.log(options)	//иҝҷйҮҢеҸҜд»Ҙе®һзҺ°и·іиҪ¬жү“ејҖжӯӨappпјҢиҝӣе…ҘжҢҮе®ҡйЎөйқўгҖӮ
		},
		onHide: function () {
			console.log('App Hide')
		},

		onLastPageBackPress: function () {
			console.log('App LastPageBackPress')
			if (firstBackTime == 0) {
				uni.showToast({
					title: 'еҶҚжҢүдёҖж¬ЎйҖҖеҮәеә”з”Ё',
					position: 'bottom',
				})
				firstBackTime = Date.now()
				setTimeout(() => {
					firstBackTime = 0
				}, 2000)
			} else if (Date.now() - firstBackTime < 2000) {
				firstBackTime = Date.now()
				uni.exit()
			}
		},

		onError: function(err: any){
			console.log(err)	//зӣ‘еҗ¬е…ЁеұҖй”ҷиҜҜпјҢеҸҜд»ҘеңЁиҝҷйҮҢе®һзҺ°й”ҷиҜҜдёҠжҠҘ
		},
		onExit: function () {
			console.log('App Exit')
			

			unregisterOSPermission()  // еҸ–ж¶Ҳе…ЁеұҖзӣ‘еҗ¬osжқғйҷҗ

			removeRouterPermission()	//з§»йҷӨи·Ҝз”ұжӢҰжҲӘжқғйҷҗ
		},
	}
</script>

<style>
	/*жҜҸдёӘйЎөйқўе…¬е…ұcss */
	@import "pkg/style/app.css";
</style>