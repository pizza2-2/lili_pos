<template>

	<scroll-view class="page-scroll" scroll-y="true">

		<view class="page">
			<view class="hero-card">
				<text class="hero-title">Bottom Select 测试页</text>
				<text class="hero-desc">用于验证触发器右侧“编辑 / 新增”入口的位置、点击事件和选择交互。</text>
			</view>

			<view class="panel-card">
				<text class="section-title">默认触发器测试</text>
				<text class="section-desc">点击输入框区域会打开底部选择器，点击“编辑 / 新增”只触发事件，不会展开面板。</text>

				<lili_bottom-select
					:fetchData="fetchCryptoOptions"
					:value="selectedValue"
					title="选择币种"
					placeholder="请选择测试币种"
					searchPlaceholder="输入币种名称搜索"
					@change="handleChange"
					@edit="handleEdit"
					@add="handleAdd"
				/>
			</view>

			<view class="panel-card">
				<text class="section-title">当前结果</text>
				<view class="info-row">
					<text class="info-label">当前 value</text>
					<text class="info-value">{{ selectedValue == '' ? '(空)' : selectedValue }}</text>
				</view>
				<view class="info-row">
					<text class="info-label">当前 text</text>
					<text class="info-value">{{ selectedText == '' ? '(空)' : selectedText }}</text>
				</view>
				<view class="info-row">
					<text class="info-label">最近动作</text>
					<text class="info-value">{{ latestAction }}</text>
				</view>
			</view>
		</view>

	</scroll-view>

</template>

<script setup lang="uts">
import { ref } from 'vue'

type CryptoOption = {
	value: string
	text: string
}

const selectedValue = ref<string>('')
const selectedText = ref<string>('')
const latestAction = ref<string>('等待交互')

const cryptoSeed: CryptoOption[] = [
	{ value: 'btc', text: 'Bitcoin' } as CryptoOption,
	{ value: 'eth', text: 'Ethereum' } as CryptoOption,
	{ value: 'sol', text: 'Solana' } as CryptoOption,
	{ value: 'bnb', text: 'BNB' } as CryptoOption,
	{ value: 'xrp', text: 'XRP' } as CryptoOption,
	{ value: 'ada', text: 'Cardano' } as CryptoOption,
	{ value: 'doge', text: 'Dogecoin' } as CryptoOption,
	{ value: 'dot', text: 'Polkadot' } as CryptoOption,
] as CryptoOption[]

function normalizeKeyword(params: UTSJSONObject) : string {
	const keywordValue = params['keyword']
	if (keywordValue == null) return ''
	return ('' + keywordValue).toLowerCase()
}

function normalizePage(params: UTSJSONObject) : number {
	const pageValue = params['page']
	if (pageValue == null) return 1
	return pageValue as number
}

function normalizePageSize(params: UTSJSONObject) : number {
	const pageSizeValue = params['pageSize']
	if (pageSizeValue == null) return 20
	return pageSizeValue as number
}

function normalizeId(params: UTSJSONObject) : string {
	const idValue = params['id']
	if (idValue == null) return ''
	return '' + idValue
}

function optionToJson(option: CryptoOption) : UTSJSONObject {
	return {
		value: option.value,
		text: option.text,
	} as UTSJSONObject
}

async function fetchCryptoOptions(params: UTSJSONObject) : Promise<UTSJSONObject> {
	const keyword = normalizeKeyword(params)
	const page = normalizePage(params)
	const pageSize = normalizePageSize(params)
	const id = normalizeId(params)

	let filtered: CryptoOption[] = []
	if (id != '') {
		for (let i = 0; i < cryptoSeed.length; i++) {
			const item = cryptoSeed[i]
			if (item.value == id) {
				filtered.push(item)
				break
			}
		}
	} else {
		for (let i = 0; i < cryptoSeed.length; i++) {
			const item = cryptoSeed[i]
			const lowerText = item.text.toLowerCase()
			const lowerValue = item.value.toLowerCase()
			if (keyword == '' || lowerText.indexOf(keyword) >= 0 || lowerValue.indexOf(keyword) >= 0) {
				filtered.push(item)
			}
		}
	}

	const start = (page - 1) * pageSize
	let end = start + pageSize
	if (end > filtered.length) {
		end = filtered.length
	}

	const pageItems: UTSJSONObject[] = []
	for (let i = start; i < end; i++) {
		pageItems.push(optionToJson(filtered[i]))
	}

	return {
		data: pageItems,
		total: filtered.length,
	} as UTSJSONObject
}

function handleChange(payload: UTSJSONObject) {
	const value = payload['value'] == null ? '' : '' + payload['value']
	const textValue = payload['text']
	const text = textValue == null ? '' : textValue as string
	selectedValue.value = value
	selectedText.value = text
	latestAction.value = `选择了 ${text} (${value})`
	uni.showToast({ title: `已选 ${text}`, icon: 'none' })
}

function handleEdit() {
	latestAction.value = '点击了编辑，后续可跳转到编辑页'
	uni.showToast({ title: '编辑事件已触发', icon: 'none' })
}

function handleAdd() {
	latestAction.value = '点击了新增，后续可跳转到新增页'
	uni.showToast({ title: '新增事件已触发', icon: 'none' })
}
</script>

