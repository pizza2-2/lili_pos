<template>
	<scroll-view class="page-scroll" style="flex:1" direction="vertical">
		<view class="page">
			<view class="hero">
				<text class="hero-title">Lili Preview Test</text>
				<text class="hero-desc">这个页面用于测试缩略图点击预览、全屏切换、保存到相册和系统分享。</text>
			</view>

			<view class="section">
				<text class="section-title">头像样式</text>
				<lili-preview
					:images="avatarImages"
					:visible="avatarPreviewVisible"
					:thumbSize="72"
					:radius="36"
					:gap="12"
					@update:visible="handleAvatarVisibleChange"
					@preview="handleAvatarPreviewEvent"
					@save="handleSaveEvent"
					@share="handleShareEvent"
				/>
			</view>

			<view class="section">
				<text class="section-title">宫格样式</text>
				<lili-preview
					:images="galleryImages"
					:visible="galleryPreviewVisible"
					:thumbSize="96"
					:radius="16"
					:gap="12"
					@update:visible="handleGalleryVisibleChange"
					@preview="handleGalleryPreviewEvent"
					@save="handleSaveEvent"
					@share="handleShareEvent"
				/>
			</view>

			<view class="section">
				<text class="section-title">最近操作</text>
				<view class="log-card">
					<text class="log-text">{{ eventLog }}</text>
				</view>
			</view>
		</view>
	</scroll-view>
</template>

<script setup lang="uts">
import { ref } from 'vue'

const avatarImages = ref<string[]>([
	'https://img0.baidu.com/it/u=3701141354,3470104905&fm=253&fmt=auto&app=120&f=JPEG?w=800&h=800',
	'https://img1.baidu.com/it/u=3290819308,452036545&fm=253&fmt=auto&app=138&f=JPEG?w=500&h=667',
	'https://img2.baidu.com/it/u=784868447,2698648098&fm=253&fmt=auto&app=138&f=JPEG?w=889&h=500',
])

const galleryImages = ref<string[]>([
	'https://img1.baidu.com/it/u=3290819308,452036545&fm=253&fmt=auto&app=138&f=JPEG?w=500&h=667',
	'https://img2.baidu.com/it/u=784868447,2698648098&fm=253&fmt=auto&app=138&f=JPEG?w=889&h=500',
	'https://img0.baidu.com/it/u=3701141354,3470104905&fm=253&fmt=auto&app=120&f=JPEG?w=800&h=800',
])

const eventLog = ref<string>('等待操作')
const avatarPreviewVisible = ref<boolean>(false)
const galleryPreviewVisible = ref<boolean>(false)

function readPayloadString(payload: UTSJSONObject, key: string) : string {
	const value = payload[key]
	if (value == null) {
		return ''
	}
	return value as string
}

function handleAvatarPreviewEvent(payload: UTSJSONObject) {
	const path = readPayloadString(payload, 'path')
	avatarPreviewVisible.value = true
	eventLog.value = '打开头像预览: ' + path
}

function handleGalleryPreviewEvent(payload: UTSJSONObject) {
	const path = readPayloadString(payload, 'path')
	galleryPreviewVisible.value = true
	eventLog.value = '打开宫格预览: ' + path
}

function handleSaveEvent(payload: UTSJSONObject) {
	const path = readPayloadString(payload, 'path')
	eventLog.value = '已保存图片: ' + path
}

function handleShareEvent(payload: UTSJSONObject) {
	const path = readPayloadString(payload, 'path')
	eventLog.value = '已触发分享: ' + path
}

function handleAvatarVisibleChange(value: boolean) {
	avatarPreviewVisible.value = value
}

function handleGalleryVisibleChange(value: boolean) {
	galleryPreviewVisible.value = value
}

onBackPress(() : boolean | null => {
	if (avatarPreviewVisible.value) {
		avatarPreviewVisible.value = false
		return true
	}
	if (galleryPreviewVisible.value) {
		galleryPreviewVisible.value = false
		return true
	}
	return false
})
</script>

