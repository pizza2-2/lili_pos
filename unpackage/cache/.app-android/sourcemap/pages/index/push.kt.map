<template>

	<scroll-view style="flex:1">

	
		<text class="m-20 bg-grey p-20">
			<text class="color-grey fs-28">
				开发unipush 2.0 请参照官方文档。这里只实现了简单的发送功能。后续再添加其它功能。
			</text>
		</text>
	
		<text class="m-y-20">{{clientID}}</text>
		<button type="primary" @click="getClientID">获取ClientID</button>
		
		<view class="mt-40 bg-grey p-20">
			<view class="mt-10 flexr flex-ai-c">
				<text class="fs-28">推送标题：</text>
				<input class="p-10 bg-white fs-32" v-model="title" type="text" placeholder="推送的标题" />
			</view>
			<view class="mt-10 flexr flex-ai-c">
				<text class="fs-28">推送内容：</text>
				<input class="p-10 bg-white fs-32" v-model="content" type="text" placeholder="推送的内容" />
			</view>
		</view>
		
		<button class="mt-20" type="primary" :disabled="second < 90 || title == '' || content == '' " @click="testPushClick">
			{{ second < 90 ? second+'秒后可重新发送' : '云函数发出推送' }}
		</button>
		
		<text class="mt-20 color-red fs-28">
			实现了发送到此设备ClientId的功能。实际业务中可以使用网络请求调用\n
			一定要使用自定义基座测试。\n
			iOS 和 鸿蒙 要在DCloud开发者中心做配置。否则无效。
		</text>
		
		<button class="mt-20" type="primary" @click="clearBadgeClick">
			清除应用图标的角标
		</button>
		
		<view class="bottom w100 flex-jc-c flex-ai-c">
			<text class="color-base fs-30">
				微信公众号搜索：FC程序开发
			</text>
		</view>

	</scroll-view>

</template>

<script setup>
	import { fcBase64Encode } from "@/pkg/util/crypto"
	
	//防止盗刷接口
	import {pushTime,setPushTime,getPushTime} from '@/store/delay.uts'
	import { fcTimeSubSecond } from '@/pkg/util/time.uts'
	const second = ref(90)
	const interval = ref<number>(0)
	
	const clientID = ref("")
	function getClientID(){
		// uni-app客户端获取push客户端标记
		uni.getPushClientId({
			success: (res) => {
				clientID.value = res.cid
				console.log('客户端推送标识:',clientID.value)
			},
			fail(err) {
				console.log(err)
			}
		})
	}
	
	const title = ref('fc-baseX-uniCloud发来的推送标题')
	const content = ref('恭喜你收到了来自fc-baseX-uniCloud的推送信息')
	
	// 启动定时器
	function startInterval(){
		interval.value = setInterval(() => {
			second.value--;
			if (second.value <= 0) {
				clearInterval(interval.value);
				second.value = 90;
			}
		}, 1000);
	}
	
	function testPushClick(){
		
		//坑，button中设置的disabled在鸿蒙上无效，在这里再做一次判断。等待官方修复此bug
		if(second.value < 90 || title.value == '' || content.value == '' ){
			return
		}
		uni.showLoading({ title: 'loading' })
		uni.getPushClientId({
			success: (res) => {
				// 使用云函数的方式调用推送
				uniCloud.callFunction({
					name: 'testUniPush',
					data: {
						title: title.value,
						content: content.value,
						clientID: res.cid,
						payload: "这里可以传送自定义信息"
					}
				}).then(res => {
					console.log(res)
					setTimeout(() => {
						uni.showToast({
							title:"发送推送成功，请在通知栏中查看",
							icon:"none"
						})
					},200)
					
					setPushTime(new Date().getTime())	//本地存储获取时间
					startInterval()						//启动定时器
				}).catch((err) => {
					console.log(err)
					setTimeout(() => {
						uni.showToast({
							title:"消息发送失败，查看控制台信息。",
							icon:"none"
						})
					},200)
				}).finally(() =>{
					uni.hideLoading()
				})
			},
			fail(err) {
				console.log(err)
			}
		})
	}
	
	function clearBadgeClick(){
		uni.setAppBadgeNumber(0)
	}
	
	onLoad(() => {
		uni.showModal({
			title:"注意",
			content:"该功能使用的是免费版uniCloud服务空间，请勿频繁刷此接口。\n如果没有收到推送那原因是：\n1.服务空间的资源使用完了。\n2.把服务空间关了。\n3.推送有延迟，稍等一下。\n但功能是正常的，可以把demo下载下来，使用自己的服务空间测试。",
			showCancel:false
		})
		
		getPushTime()	//从本地存储中获取上次更新时间
		var subSecond = Math.abs(fcTimeSubSecond(pushTime.value))	//取绝对值
		// 判断已经过去90s了
		if(subSecond > 90){
			second.value = 90
		}else{
			second.value = 90 - subSecond
			//启动定时器
			startInterval()
		}
	})
	
	onUnload(() => {
		clearInterval(interval.value);
	})
</script>

<style>
	.input{
		height: 50rpx;
	}
	.bottom{
		position: absolute;
		left: 0;
		bottom: var(--uni-safe-area-inset-bottom);
	}
</style>
