<template>

	<scroll-view class="flex-ai-c" style="flex:1">

		
		<text class="m-20 bg-grey p-20">
			<text class="color-grey fs-28">
				获取权限代码封装在了
			</text>
			<text class="color-red fs-28">
				/pkg/util/osPermission.uts
			</text>
			<text class="color-grey fs-28">
				文件中。一定要在
			</text>
			<text class="color-red fs-28">
				manifest.json -> 安卓/iOS/鸿蒙 App配置
			</text>
			<text class="color-grey fs-28">
				中配置所需要的权限。用不到的权限不要配置。安卓端使用某些权限时要在
			</text>
			<text class="color-red fs-28">
				额外添加的权限
			</text>
			<text class="color-grey fs-28">
				中添加对应的权限。详见下方的文档。
			</text>
			<text class="color-red fs-28">
				在用户未同意隐私政策之前，不要调用任何权限API，否则审核不通过。
			</text>
		</text>
		
		<button type="primary" @click="getLocation">获取定位</button>
		<text v-if="location">获取的经纬度：{{location?.latitude}} -- {{location?.longitude}}</text>
		
		<button type="primary" class="m-y-10" @click="getCamera">获取相机</button>
		<button type="primary" @click="getAlbum">获取相册</button>
		
		<image :src="image" mode="heightFix" style="height: 400rpx;"></image>
		
		<view class="bottom w100 flex-jc-c flex-ai-c">
			<text class="color-base fs-30">
				微信公众号搜索：FC程序开发
			</text>
		</view>

	</scroll-view>

</template>

<script setup>
	import { getLocationAsync,getCameraAsync,getAlbumAsync } from '@/pkg/util/osPermission.uts'
	
	const location = ref<GetLocationSuccess | null>(null)
	//获取定位信息
	async function getLocation(){
		try {
			location.value = await getLocationAsync()
			console.log(location)
		} catch (error) {
			//TODO handle the exception
			console.log(error)
		}
	}
	
	const image = ref("")
	//调用摄像头
	async function getCamera(){
		try {
			const imageInfo = await getCameraAsync()
			console.log(imageInfo)
			image.value = imageInfo.tempFilePaths[0]
		} catch (error) {
			//TODO handle the exception
			console.log(error)
		}
	}
	//调用相册
	async function getAlbum(){
		try {
			const imageInfo = await getAlbumAsync(1)
			console.log(imageInfo)
			image.value = imageInfo.tempFilePaths[0]
		} catch (error) {
			//TODO handle the exception
			console.log(error)
		}
	}
</script>

<style>
	.bottom{
		position: absolute;
		left: 0;
		bottom: var(--uni-safe-area-inset-bottom);
	}
</style>
