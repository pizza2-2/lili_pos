	font-size: 22px;
	font-weight: bold;
	color: #111827;
}

.desc {
	font-size: 14px;
	color: #667085;
	margin-top: 8px;
	line-height: 22px;
}

.card {
	background-color: #FFFFFF;
	border-radius: 16px;
	padding: 16px;
	margin-top: 14px;
	border-width: 1px;
	border-color: #E7ECF2;
	border-style: solid;
}

.card-label {
	font-size: 13px;
	color: #94A3B8;
}

.card-value {
	font-size: 16px;
	color: #0F172A;
	margin-top: 8px;
	line-height: 22px;
}

.btn-row {
	flex-direction: row;
	margin-top: 18px;
}

.btn-row-single {
	margin-top: 10px;
}

.btn {
	flex: 1;
	height: 44px;
	border-radius: 14px;
	align-items: center;
	justify-content: center;
}

.btn-primary {
	background-color: #0F172A;
	margin-right: 10px;
}

.btn-secondary {
	background-color: #E2E8F0;
}

.btn-text {
	font-size: 14px;
