<template>
	<scroll-view class="page-scroll" style="flex:1" direction="vertical">
		<view class="page">
			<lili-universal-filter
				title="订单列表"
				:showBack="true"
				:showHome="true"
				:showSearch="true"
				:showFilter="true"
				:showMenu="true"
				:showScan="true"
				:filterActive="filterActive"
				:searchValue="navSearch"
				searchPlaceholder="搜索订单/客户/手机号"
				@searchInput="onNavSearchInput"
				@searchConfirm="onNavSearchConfirm"
				@searchClear="onNavSearchClear"
				@filter="onNavFilter"
				@menu="onNavMenu"
				@home="onNavHome"
				@back="onNavBack"
				@scan="onNavScan"
			/>

			<view class="content">
				<text class="title">UniversalFilter 测试页</text>
				<text class="desc">这个页面用于验证返回、首页、搜索、筛选和菜单按钮是否正常触发。</text>

				<view class="card">
					<text class="card-label">当前搜索值</text>
					<text class="card-value">{{ navSearch == '' ? '(空)' : navSearch }}</text>
				</view>

				<view class="card">
					<text class="card-label">最近一次操作</text>
					<text class="card-value">{{ navActionText }}</text>
				</view>

				<view class="card">
					<text class="card-label">筛选红点状态</text>
					<text class="card-value">{{ filterActive ? '激活中' : '未激活' }}</text>
				</view>

	
				<view class="btn-row">
					<view class="btn btn-primary" @click="toggleFilterActive">
						<text class="btn-text">切换筛选红点</text>
					</view>
					<view class="btn btn-secondary" @click="fillSearchDemo">
						<text class="btn-text btn-text-dark">填充测试搜索词</text>
					</view>
				</view>

				<view class="btn-row btn-row-single">
					<view class="btn btn-primary" @click="goToCryptoPage">
						<text class="btn-text">跳转到 Crypto 页面</text>
					</view>
				</view>

				<view class="btn-row btn-row-single">
					<view class="btn btn-primary" @click="goToUploadPage">
						<text class="btn-text">跳转到 Upload 页面</text>
					</view>
				</view>

				<view class="btn-row">
					<view class="btn btn-primary" @click="openBasicPopup">
						<text class="btn-text">打开确认弹窗</text>
					</view>
					<view class="btn btn-secondary" @click="openSavePopup">
						<text class="btn-text btn-text-dark">打开保存弹窗</text>
					</view>
				</view>
			</view>

			<lili-popup
				:visible="basicPopupVisible"
				title="删除提示"
				content="确认删除这条测试数据吗？"
				cancelText="取消"
				confirmText="确认删除"
				:confirmDanger="true"
				@update:visible="onBasicPopupVisibleChange"
				@cancel="onBasicPopupCancel"
				@confirm="onBasicPopupConfirm"
				@close="onBasicPopupClose"
			/>

			<lili-popup
				:visible="savePopupVisible"
				title="是否保存"
				content="当前内容已修改，是否保存后再退出？"
				auxiliaryText="退出"
				cancelText="取消保存"
				confirmText="保存"
				@update:visible="onSavePopupVisibleChange"
				@auxiliary="onSavePopupAuxiliary"
				@cancel="onSavePopupCancel"
				@confirm="onSavePopupConfirm"
				@close="onSavePopupClose"
			/>
		</view>
	</scroll-view>
</template>

<script setup lang="uts">
import { ref } from 'vue'

const navSearch = ref<string>('')
const filterActive = ref<boolean>(true)
const navActionText = ref<string>('等待顶部栏交互')
const basicPopupVisible = ref<boolean>(false)
const savePopupVisible = ref<boolean>(false)

function onNavSearchInput(value: string) {
	navSearch.value = value
	navActionText.value = `输入中: ${value}`
}

function onNavSearchConfirm(value: string) {
	navSearch.value = value
	navActionText.value = `确认搜索: ${value}`
	uni.showToast({ title: `搜索: ${value}`, icon: 'none' })
}

function onNavSearchClear() {
	navSearch.value = ''
	navActionText.value = '已清空搜索'
	uni.showToast({ title: '已清空搜索', icon: 'none' })
}

function onNavFilter() {
	filterActive.value = !filterActive.value
	navActionText.value = filterActive.value ? '点击筛选: 当前有激活筛选' : '点击筛选: 当前无激活筛选'
	uni.showToast({ title: '筛选按钮已触发', icon: 'none' })
}

function onNavMenu() {
	navActionText.value = '点击菜单: 侧边栏待接入'
	uni.showToast({ title: '菜单按钮已触发', icon: 'none' })
}

function onNavHome() {
	navActionText.value = '点击首页: 已触发返回首页'
}

function onNavBack() {
	navActionText.value = '点击返回: 已触发返回事件'
}

function onNavScan() {
	navActionText.value = '点击扫码: 准备进入扫码页面'
	uni.showToast({ title: '扫码页面待接入', icon: 'none' })
}

function toggleFilterActive() {
	filterActive.value = !filterActive.value
	navActionText.value = filterActive.value ? '手动设置: 筛选红点已打开' : '手动设置: 筛选红点已关闭'
}

function fillSearchDemo() {
	navSearch.value = '测试订单A001'
	navActionText.value = '已填充测试搜索词'
}

function goToCryptoPage() {
	uni.navigateTo({
		url: '/pages/index/crypto',
	})
}

function goToUploadPage() {
	uni.navigateTo({
		url: '/pages/index/http',
	})
}

function openBasicPopup() {
	basicPopupVisible.value = true
	navActionText.value = '打开基础确认弹窗'
}

function openSavePopup() {
	savePopupVisible.value = true
	navActionText.value = '打开保存确认弹窗'
}

function onBasicPopupVisibleChange(value: boolean) {
	basicPopupVisible.value = value
}

function onSavePopupVisibleChange(value: boolean) {
	savePopupVisible.value = value
}

function onBasicPopupCancel() {
	navActionText.value = '基础弹窗: 点击取消'
}

function onBasicPopupConfirm() {
	navActionText.value = '基础弹窗: 点击确认删除'
}

function onBasicPopupClose(action: string) {
	navActionText.value = `基础弹窗关闭: ${action}`
}

function onSavePopupAuxiliary() {
	navActionText.value = '保存弹窗: 点击退出'
}

function onSavePopupCancel() {
	navActionText.value = '保存弹窗: 点击取消保存'
}

function onSavePopupConfirm() {
	navActionText.value = '保存弹窗: 点击保存'
}

function onSavePopupClose(action: string) {
	navActionText.value = `保存弹窗关闭: ${action}`
}
</script>

<style>
.page-scroll {
	background-color: #F5F7FA;
}

.page {
	background-color: #F5F7FA;
}

.content {
	padding-left: 16px;
	padding-right: 16px;
