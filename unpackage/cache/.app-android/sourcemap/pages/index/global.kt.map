<template>
	<scroll-view class="page-scroll" style="flex:1" direction="vertical">
		<view class="page">
			<view class="hero">
				<text class="hero-title">Lili Preview</text>
				<text class="hero-desc">点击缩略图进入全屏预览，支持多图切换、系统分享和保存到相册。</text>
			</view>

			<view class="section">
				<text class="section-title">头像尺寸预览</text>
				<lili-preview
					:images="avatarImages"
					:thumbSize="72"
					:radius="36"
					:gap="12"
					@preview="handlePreviewEvent"
					@save="handleSaveEvent"
					@share="handleShareEvent"
				/>
			</view>

			<view class="section">
				<text class="section-title">方图预览</text>
				<lili-preview
					:images="galleryImages"
					:thumbSize="96"
					:radius="16"
					:gap="12"
					@preview="handlePreviewEvent"
					@save="handleSaveEvent"
					@share="handleShareEvent"
				/>
			</view>

			<view class="section">
				<text class="section-title">最近一次操作</text>
				<view class="log-card">
					<text class="log-text">{{ eventLog }}</text>
				</view>
			</view>
		</view>
	</scroll-view>
</template>

<script setup lang="uts">
import { ref } from 'vue'

const avatarImages = ref<string[]>([
	'https://img0.baidu.com/it/u=3701141354,3470104905&fm=253&fmt=auto&app=120&f=JPEG?w=800&h=800',
	'https://img1.baidu.com/it/u=3290819308,452036545&fm=253&fmt=auto&app=138&f=JPEG?w=500&h=667',
	'https://img2.baidu.com/it/u=784868447,2698648098&fm=253&fmt=auto&app=138&f=JPEG?w=889&h=500',
])

const galleryImages = ref<string[]>([
	'https://img1.baidu.com/it/u=3290819308,452036545&fm=253&fmt=auto&app=138&f=JPEG?w=500&h=667',
	'https://img2.baidu.com/it/u=784868447,2698648098&fm=253&fmt=auto&app=138&f=JPEG?w=889&h=500',
	'https://img0.baidu.com/it/u=3701141354,3470104905&fm=253&fmt=auto&app=120&f=JPEG?w=800&h=800',
])

const eventLog = ref<string>('等待操作')

function readPayloadString(payload: UTSJSONObject, key: string) : string {
	const value = payload[key]
	if (value == null) {
		return ''
	}
	return value as string
}

function handlePreviewEvent(payload: UTSJSONObject) {
	const path = readPayloadString(payload, 'path')
	eventLog.value = '打开预览: ' + path
}

function handleSaveEvent(payload: UTSJSONObject) {
	const path = readPayloadString(payload, 'path')
	eventLog.value = '已保存图片: ' + path
}

function handleShareEvent(payload: UTSJSONObject) {
	const path = readPayloadString(payload, 'path')
	eventLog.value = '已触发分享: ' + path
}
</script>

