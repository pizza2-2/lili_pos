<template>

	<scroll-view class=" flex-ai-c" style="flex:1">

	
		<text class="m-20 bg-grey p-20">
			<text class="color-grey fs-28">
				版本更新使用到了uniapp官方的uni-admin和uniCloud，使用这个前提需要把这两个配置好，可以看下面的文档。注意：uniapp-x App端目前不支持热更新。只能整包更新。（官方后续会出热更新）
				\n
				可以把获取App更新放在
			</text>
			<text class="color-red fs-28">
				/store/global.uts
			</text>
			<text class="color-grey fs-28">
				文件中（代码中注释了，打开注释即可）。这样就能在每次启动app的时候，检查更新。
			</text>
		</text>
		

		<button class="mt-40" type="primary" :disabled="second < 90"  @click="appUpdateClick">
			{{ second < 90 ? second+'秒后可重新获取' : '获取应用更新' }}
		</button>
		
		<view class="bottom w100 flex-jc-c flex-ai-c">
			<text class="color-base fs-30">
				微信公众号搜索：FC程序开发
			</text>
		</view>

	</scroll-view>

</template>

<script setup>
	import checkUpdate from '@/uni_modules/uni-upgrade-center-app/utils/check-update'

	//防止盗刷接口
	import {updateTime,setUpdateTime,getUpdateTime} from '@/store/delay.uts'
	import { fcTimeSubSecond } from '@/pkg/util/time.uts'
	const second = ref(90)
	const interval = ref<number>(0)

	// 启动定时器
	function startInterval(){
		interval.value = setInterval(() => {
			second.value--;
			if (second.value <= 0) {
				clearInterval(interval.value);
				second.value = 90;
			}
		}, 1000);
	}

	async function appUpdateClick(){
		if(second.value < 90) return
		uni.showLoading({ title: 'loading' })
		try {
			await checkUpdate()					//请求应用升级更新
			uni.hideLoading()
			setUpdateTime(new Date().getTime())	//本地存储获取时间
			startInterval()						//启动定时器
		} catch (error) {
			//TODO handle the exception
			console.log(error)
			uni.hideLoading()
			uni.showToast({
				title:"消息发送失败，查看控制台信息。",
				icon:"none"
			})
		}
	}
	
	onLoad(() => {
		uni.showModal({
			title:"注意",
			content:"该功能使用的是免费版uniCloud服务空间，请勿频繁刷此接口。\n如果没有弹出更新弹窗原因是：\n1.服务空间的资源使用完了。\n2.把服务空间关了。\n3.网络请求有延迟，稍等一下。\n但功能是正常的，可以把demo下载下来，使用自己的服务空间测试。",
			showCancel:false
		})
		
		getUpdateTime()	//从本地存储中获取上次更新时间
		var subSecond = Math.abs(fcTimeSubSecond(updateTime.value))	//取绝对值
		// 判断已经过去90s了
		if(subSecond > 90){
			second.value = 90
		}else{
			second.value = 90 - subSecond
			//启动定时器
			startInterval()
		}
	})
	
	onUnload(() => {
		clearInterval(interval.value);
	})
</script>

<style>
	.bottom{
		position: absolute;
		left: 0;
		bottom: var(--uni-safe-area-inset-bottom);
	}
</style>
