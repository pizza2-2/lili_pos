<template>

	<scroll-view style="flex:1">

	
	<text class="m-20 bg-grey p-20">
		<text class="color-grey fs-28">
			文件位置在
		</text>
		<text class="color-red fs-28">
			/pkg/util/time.uts
		</text>
		<text class="color-grey fs-28">
			中，封装一些常用的时间处理方法。由于是使用uts语言生成的，理论上来说是支持全平台。
		</text>
	</text>
	
	<view class="flexr p-x-20 mt-40">
		<view class="bg-base" style="width: 20rpx;border-radius: 8rpx;"></view>
		<text class="ml-10">格式化时间</text>
	</view>
	
	<view class="m-20 bg-grey p-20">
		<text class="color-red">格式化后的时间：{{dateValue}}</text>
		<button type="primary" class="mt-20" @click="btnClick1('number')">格式化时间（时间戳number类型）</button>
		<button type="primary" class="mt-20" @click="btnClick1('date')">格式化时间（时间Date类型）</button>
		<button type="primary" class="mt-20" @click="btnClick1('string')">格式化时间（UTC字符串类型）</button>
		<button type="primary" class="mt-20" @click="btnClick1('number','YYYY-MM-DD')">格式化时间（显示年月日）</button>
		<button type="primary" class="mt-20" @click="btnClick1('number','HH:mm:ss')">格式化时间（显示时分秒）</button>
	</view>
	
	<view class="flexr p-x-20 mt-40">
		<view class="bg-base" style="width: 20rpx;border-radius: 8rpx;"></view>
		<text class="ml-10">获取指定时间的前后时间</text>
	</view>
	
	<view class="m-20 bg-grey p-20">
		<text class="color-red">前5分钟的时间：{{offsetTime1}}</text>
		<text class="color-red">后5分钟的时间：{{offsetTime2}}</text>
		<button type="primary" class="mt-20" @click="btnClick2()">获取5分钟前后的时间</button>
		<text class="color-red">前5小时的时间：{{offsetTime3}}</text>
		<text class="color-red">后5小时的时间：{{offsetTime4}}</text>
		<button type="primary" class="mt-20" @click="btnClick3()">获取5小时前后的时间</button>
		<text>2025-10-1 20:08:08前一天的时间：</text>
		<text class="color-red">{{offsetTime5}}</text>
		<text>2025-10-1 20:08:08后一天的时间：</text>
		<text class="color-red">{{offsetTime6}}</text>
		<button type="primary" class="mt-20" @click="btnClick4()">2025/10/01 20:08:08前后1天时间</button>
	</view>
	
	<view class="flexr p-x-20 mt-40">
		<view class="bg-base" style="width: 20rpx;border-radius: 8rpx;"></view>
		<text class="ml-10">获取两个时间相差的秒数</text>
	</view>
	
	<view class="m-20 bg-grey p-20">
		<text class="color-red">随机获取的时间：{{offsetTime7}}</text>
		<text class="color-red">距离当前时间相差的秒数为: {{ subSecond }} </text>
		<button type="primary" class="mt-20" @click="btnClick5()">随机获取一个时间</button>
		<text class="color-red">
			可以根据此，做时间判断，比如常见显示的\n
			刚刚、n分钟前、n小时前、n天前、n星期前、n月前...\n
			不想要负数，请使用绝对值 Math.abs() 处理
		</text>
	</view>
	
	<view class="mt-40 bottom w100 flex-jc-c flex-ai-c">
		<text class="color-base fs-30">
			微信公众号搜索：FC程序开发
		</text>
	</view>

	</scroll-view>

</template>

<script setup>
	import { fcTimeFormat,fcTimeM2S,fcTimeH2S,fcTimeD2S,fcTimeOffsetSecond,fcTimeSubSecond } from '@/pkg/util/time.uts'
	
	const dateValue = ref('')
	
	/**
	 * 如果指定时间格式，建议使用 YYYY/MM/DD HH:mm:ss ，不要使用 YYYY-MM-DD HH:mm:ss
	 * 因为 YYYY/MM/DD HH:mm:ss 这种在iOS下会失败，DCloud官方bug，等待修复
	 * 补充，HBuilderX 4.76 alpha 修复了此bug，可以使用 YYYY-MM-DD HH:mm:ss 格式。
	 */
	function btnClick1(type:'number' | 'date' | 'string',format:string = 'YYYY/MM/DD HH:mm:ss'){
		if(type == "number"){
			var number = new Date().getTime()
			dateValue.value = fcTimeFormat(number,format)
		}else if(type == "date"){
			var date = new Date()
			dateValue.value = fcTimeFormat(date,format)
		}else {
			var string = "1949-10-01T21:00:00.171+08:00"
			dateValue.value = fcTimeFormat(string,format)
		}
	}
	
	const offsetTime1 = ref('')
	const offsetTime2 = ref('')
	const offsetTime3 = ref('')
	const offsetTime4 = ref('')
	const offsetTime5 = ref('')
	const offsetTime6 = ref('')
	
	function btnClick2(){
		var val1 = fcTimeOffsetSecond(-fcTimeM2S(5))	//5分钟前的时间戳
		var val2 = fcTimeOffsetSecond(fcTimeM2S(5))		//5分钟后的时间戳
		offsetTime1.value = fcTimeFormat(val1)
		offsetTime2.value = fcTimeFormat(val2)
	}
	
	function btnClick3(){
		var val1 = fcTimeOffsetSecond(-fcTimeH2S(5))	//5小时前的时间戳
		var val2 = fcTimeOffsetSecond(fcTimeH2S(5))		//5小时后的时间戳
		offsetTime3.value = fcTimeFormat(val1)
		offsetTime4.value = fcTimeFormat(val2)
	}
	
	function btnClick4(){
		/*
			为什么用2025/10/01 而不用2025-10-01
			因为截至写这段代码时间为止。iOS系统解析不了2025-10-01这种格式（虽然DCloud官网文档说支持。。。）
			等待官方修复这个bug
		*/
		var val1 = fcTimeOffsetSecond(-fcTimeD2S(1),'2025/10/01 20:08:08')	//2025/10/1 20:08:08前一天的时间戳
		var val2 = fcTimeOffsetSecond(fcTimeD2S(1),'2025/10/01 20:08:08')	//2025/10/1 20:08:08后一天的时间戳
		offsetTime5.value = fcTimeFormat(val1)
		offsetTime6.value = fcTimeFormat(val2)
	}
	
	const offsetTime7 = ref('')
	const subSecond = ref(0)
	
	function btnClick5(){
		var date = new Date()
		var minTime = fcTimeOffsetSecond(-fcTimeD2S(1),date) as number	//1天前的时间戳
		var maxTime = fcTimeOffsetSecond(fcTimeD2S(1),date) as number	//1天后的时间戳
		// 从两个时间戳之间随机获取1个数
		const [actualMin, actualMax] = minTime < maxTime ? [minTime, maxTime] : [maxTime, minTime];
		var timeNum = Math.floor(actualMin + (actualMax - actualMin + 1) * Math.random())
		offsetTime7.value = fcTimeFormat(timeNum,'YYYY/MM/DD HH:mm:ss')
	}
	
	watch(
		():string => offsetTime7.value,
		() => {
			if(offsetTime7.value != ''){
				subSecond.value = fcTimeSubSecond(offsetTime7.value)
			}
		}
	)
</script>

<style>
	.bottom{
		margin-bottom: var(--uni-safe-area-inset-bottom);
	}
</style>
