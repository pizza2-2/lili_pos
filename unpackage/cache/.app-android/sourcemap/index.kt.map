			// 用户未同意隐私政策则弹出“个人信息保护指引”提示框
			uni.openDialogPage({
				url: '/pages/privacy/privacy',  // 修改为应用中定义的页面地址
			})
			reject(new Error('未同意《隐私政策》，不能使用此功能！'))
			return
		}
		// 如果是安卓系统，判断拒绝的时间。(iOS 和 鸿蒙 拒绝后不会再重新获取权限，需要用户手动到设置页面打开)

		if (disAllowAlbum.value != 0 ){
			// 获取 APP 授权设置 https://doc.dcloud.net.cn/uni-app-x/api/get-app-authorize-setting.html
			const res = uni.getAppAuthorizeSetting();
			// 判断是否已授权定位 处理用户在系统设置页面开启权限的情况
			if (res.albumAuthorized != "authorized"){
				var newDate = new Date().getTime()
				// 判断拒绝的时间是否已过15分钟，未过15分钟则引导用户去系统设置。已过15分钟则再次请求定位
				if (Math.abs(newDate - disAllowAlbum.value) <= timeNumber.value * 60 * 1000 ){
